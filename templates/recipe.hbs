<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} – Kristy's Cooking Adventures</title>

  {{#if output}}
  <meta name="description" content="{{output}}" />
  {{/if}}

  <meta property="og:type" content="article" />
  <meta property="og:title" content="{{title}} – Kristy's Cooking Adventures" />
  {{#if output}}
  <meta property="og:description" content="{{output}}" />
  {{/if}}
  <meta property="og:image" content="https://kristyh89.github.io/Kristys_Cooking_Adventures/images/recipe-photos/{{image}}" />
  <meta property="og:url" content="https://kristyh89.github.io/Kristys_Cooking_Adventures/recipe/{{slug}}.html" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{title}} – Kristy's Cooking Adventures" />
  {{#if output}}
  <meta name="twitter:description" content="{{output}}" />
  {{/if}}
  <meta name="twitter:image" content="https://kristyh89.github.io/Kristys_Cooking_Adventures/images/recipe-photos/{{image}}" />

  <script type="module" src="/src/main.js"></script>
  <link rel="icon" type="image/png" href="/images/site/fork-knife.png" />
</head>

<body class="min-h-screen flex flex-col bg-[#e9f7f1]">

  {{> navbar }}

  <main class="flex-grow max-w-4xl mx-auto px-6 py-16">

    <h1 class="text-4xl font-bold text-green-700 text-center mb-6">
      {{title}}
    </h1>

    {{#if intro}}
    <p class="text-center text-gray-700 max-w-2xl mx-auto mb-10">
      {{intro}}
    </p>
    {{/if}}

    <div class="bg-white shadow-lg rounded-xl p-8 border border-gray-200">

      {{!-- SIMPLE RECIPE: has top-level ingredients/steps --}}
      {{#if ingredients}}

        <h2 class="text-lg font-bold text-green-700 mb-3">Ingredients</h2>
        <ul class="list-disc list-inside mb-6 space-y-1 text-gray-800">
          {{#each ingredients}}
          <li>{{this}}</li>
          {{/each}}
        </ul>

        {{#if optional}}
        <h3 class="text-md font-bold text-green-700 mb-2">{{optional.label}}</h3>
        <ul class="list-disc list-inside mb-6 space-y-1 text-gray-800">
          {{#each optional.items}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        {{/if}}

        <h2 class="text-lg font-bold text-green-700 mb-3">Process</h2>
        <ol class="list-decimal list-inside mb-6 space-y-2 text-gray-800">
          {{#each steps}}
          <li>{{this}}</li>
          {{/each}}
        </ol>

      {{/if}}

      {{!-- SECTIONED RECIPE: has a sections array (dough/filling/shaping/etc) --}}
      {{#if sections}}

        {{#each sections}}
        <div class="mb-8 pb-8 border-b border-gray-100 last:border-b-0 last:mb-0 last:pb-0">

          <h2 class="text-xl font-bold text-green-700 mb-4 uppercase tracking-wide">
            {{title}}
          </h2>

          {{#if ingredients}}
          <h3 class="text-sm font-semibold text-gray-500 mb-2">Ingredients</h3>
          <ul class="list-disc list-inside mb-4 space-y-1 text-gray-800">
            {{#each ingredients}}
            <li>{{this}}</li>
            {{/each}}
          </ul>
          {{/if}}

          {{#if steps}}
          <h3 class="text-sm font-semibold text-gray-500 mb-2">Process</h3>
          <ol class="list-decimal list-inside space-y-2 text-gray-800">
            {{#each steps}}
            <li>{{this}}</li>
            {{/each}}
          </ol>
          {{/if}}

        </div>
        {{/each}}

      {{/if}}

      {{#if output}}
      <h3 class="text-md font-bold text-green-700 mb-2">Result</h3>
      <p class="text-gray-700 mb-4">{{output}}</p>
      {{/if}}

      {{#if storage}}
      <h3 class="text-md font-bold text-green-700 mb-2">Storage</h3>
      <ul class="list-disc list-inside mb-4 space-y-1 text-gray-800">
        {{#each storage}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}

      {{#if tip}}
      <h3 class="text-md font-bold text-green-700 mb-2">Tip</h3>
      <p class="text-gray-700 italic">{{tip}}</p>
      {{/if}}

    </div>

    <div class="flex justify-center mt-12">
      <img
        src="/images/recipe-photos/{{image}}"
        alt="{{imageAlt}}"
        class="rounded-xl shadow-lg max-w-xl w-full"
      />
    </div>

  </main>

  {{> footer }}

</body>
</html>
